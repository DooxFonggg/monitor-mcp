// GRAFANA ALLOY CONFIGURATION FOR CLIENT/AGENT NODES

// 1. Collect Host Metrics (equivalent to Node Exporter)
prometheus.exporter.unix "agent_host" {
  procfs_path = "/host/proc"
  sysfs_path  = "/host/sys"
  rootfs_path = "/host/root"

  // Enable default collectors and systemd collector
  set_collectors = ["cpu", "diskstats", "filesystem", "loadavg", "meminfo", "netdev", "os", "stat", "uname", "systemd"]

  systemd {
    // Only monitor important services (alloy, docker, nginx, ssh) to avoid metric explosion
    unit_include = "alloy\\.service|docker\\.service|nginx\\.service|ssh\\.service"
    enable_restarts = true
    start_time      = true
  }
}

prometheus.relabel "agent_host" {
  forward_to = [prometheus.remote_write.prometheus_master.receiver]

  rule {
    target_label = "job"
    replacement  = "nodeexporter"
  }

  rule {
    target_label = "instance"
    replacement  = env("AGENT_NAME")
  }

  rule {
    target_label = "host_ip"
    replacement  = env("HOST_IP")
  }
}

prometheus.scrape "agent_host" {
  targets         = prometheus.exporter.unix.agent_host.targets
  forward_to      = [prometheus.relabel.agent_host.receiver]
  scrape_interval = "15s"
}

// 2. Collect Container Metrics from local cAdvisor
prometheus.relabel "cadvisor" {
  forward_to = [prometheus.remote_write.prometheus_master.receiver]

  rule {
    target_label = "job"
    replacement  = "cadvisor"
  }

  rule {
    target_label = "instance"
    replacement  = env("AGENT_NAME")
  }

  rule {
    target_label = "host_ip"
    replacement  = env("HOST_IP")
  }
}

prometheus.scrape "cadvisor" {
  targets = [
    {"__address__" = "cadvisor:8080"},
  ]
  forward_to      = [prometheus.relabel.cadvisor.receiver]
  scrape_interval = "15s"
}

// 3. Collect Docker Container Logs
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_logs" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    target_label = "job"
    replacement  = "docker"
  }

  rule {
    target_label = "instance"
    replacement  = env("AGENT_NAME")
  }

  rule {
    target_label = "host_ip"
    replacement  = env("HOST_IP")
  }
}

loki.source.docker "docker_logs" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_logs.output
  forward_to = [loki.write.loki_master.receiver]
}

// 4. Collect System Log Files
local.file_match "syslogs" {
  path_targets = [
    { "__path__" = "/var/log/*.log" },
    { "__path__" = "/var/log/syslog" },
  ]
}

loki.relabel "syslogs" {
  forward_to = [loki.write.loki_master.receiver]

  rule {
    target_label = "job"
    replacement  = "varlogs"
  }

  rule {
    target_label = "instance"
    replacement  = env("AGENT_NAME")
  }

  rule {
    target_label = "host_ip"
    replacement  = env("HOST_IP")
  }
}

loki.source.file "syslogs" {
  targets    = local.file_match.syslogs.targets
  forward_to = [loki.relabel.syslogs.receiver]
}

// 5. Collect Systemd Journal Logs
loki.source.journal "systemd_logs" {
  forward_to = [loki.relabel.systemd_logs.receiver]
}

loki.relabel "systemd_logs" {
  forward_to = [loki.write.loki_master.receiver]

  rule {
    target_label = "job"
    replacement  = "systemd"
  }

  rule {
    target_label = "instance"
    replacement  = env("AGENT_NAME")
  }

  rule {
    target_label = "host_ip"
    replacement  = env("HOST_IP")
  }

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
}

// 5. Outputs targeting Master Node (endpoints retrieved via environment variables)
prometheus.remote_write "prometheus_master" {
  endpoint {
    url = env("PROMETHEUS_URL")
  }
}

loki.write "loki_master" {
  endpoint {
    url = env("LOKI_URL")
  }
}
