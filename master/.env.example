# Configuration endpoints for MCP Server & Grafana Alloy
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
MCP_MODE=sse

# Logical node name for master metrics/logs
AGENT_NAME=master-node

# Host external/physical IP address for alert grouping and reporting
HOST_IP=<master-ip>

# pfSense firewall configuration for scraping node metrics
PFSENSE_IP=<pfsense-ip>
