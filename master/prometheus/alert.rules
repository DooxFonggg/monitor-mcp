# ==============================================================================
# PROMETHEUS ALERT RULES CONFIGURATION (SENIOR DEVOPS EDITION)
# ==============================================================================
# File này chứa các luật cảnh báo được phân loại rõ ràng theo mức độ nghiêm trọng:
# 1. Critical (Cao - Đỏ)   : Cần xử lý ngay lập tức để tránh sập hệ thống (System downtime).
# 2. Warning (Trung bình - Vàng): Hệ thống bị suy giảm hiệu năng hoặc tài nguyên sắp cạn kiệt.
# 3. Info (Thấp - Xanh)    : Các thông tin cảnh báo sớm hoặc hành vi bất thường nhẹ.
# ==============================================================================

groups:
  # ============================================================================
  # GROUP 1: MONITOR SERVICE STATUS (TRẠNG THÁI CÁC DỊCH VỤ GIÁM SÁT)
  # ============================================================================
  - name: monitor_services
    rules:
      # Cảnh báo khi có bất kỳ endpoint nào bị mất kết nối (down)
      - alert: ServiceDown
        expr: up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Dịch vụ quan trọng bị dừng (Instance: {{ $labels.instance }})"
          description: "Endpoint {{ $labels.instance }} của job {{ $labels.job }} không phản hồi trong hơn 1 phút."

      # Cảnh báo khi reload cấu hình Prometheus thất bại
      - alert: PrometheusConfigReloadFailed
        expr: prometheus_config_last_reload_successful == 0
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Reload cấu hình Prometheus thất bại"
          description: "Cấu hình mới của Prometheus bị lỗi cú pháp và không thể áp dụng."

  # ============================================================================
  # GROUP 2: HOST RESOURCE MONITORING (TÀI NGUYÊN MÁY CHỦ HOST)
  # ============================================================================
  - name: host_resources
    rules:
      # CPU CRITICAL: CPU của Host vượt quá 95% liên tục trong 2 phút
      - alert: HostCpuUsageCritical
        expr: 100 - (avg by(instance, host_ip) (rate(node_cpu_seconds_total{mode="idle"}[2m])) * 100) > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "CPU máy chủ quá tải nghiêm trọng (Host: {{ $labels.instance }})"
          description: "Sử dụng CPU hiện tại là {{ humanize $value }}% (Vượt ngưỡng 95% trong 2 phút)."

      # CPU WARNING: CPU của Host vượt quá 80% liên tục trong 5 phút
      - alert: HostCpuUsageWarning
        expr: 100 - (avg by(instance, host_ip) (rate(node_cpu_seconds_total{mode="idle"}[2m])) * 100) > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "CPU máy chủ tăng cao (Host: {{ $labels.instance }})"
          description: "Sử dụng CPU hiện tại là {{ humanize $value }}% (Vượt ngưỡng 80% trong 5 phút)."

      # CPU INFO: Tải hệ thống (Load Average) vượt quá số core CPU khả dụng
      - alert: HostCpuLoadAverageHigh
        expr: node_load1 > on(instance, host_ip) (count by(instance, host_ip) (node_cpu_seconds_total{mode="system"}) * 1.2)
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "Tải hệ thống cao (Host: {{ $labels.instance }})"
          description: "Chỉ số Load Average 1m là {{ $value }}, vượt quá 120% số lượng CPU core hiện có."

      # MEMORY CRITICAL: RAM khả dụng dưới 5% liên tục trong 2 phút
      - alert: HostMemoryCritical
        expr: (node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Bộ nhớ RAM sắp cạn kiệt (Host: {{ $labels.instance }})"
          description: "Sử dụng RAM đã đạt {{ humanize $value }}% (Chỉ còn dưới 5% dung lượng trống)."

      # MEMORY WARNING: RAM khả dụng dưới 15% liên tục trong 3 phút
      - alert: HostMemoryWarning
        expr: (node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100 > 85
        for: 3m
        labels:
          severity: warning
        annotations:
          summary: "Bộ nhớ RAM tăng cao (Host: {{ $labels.instance }})"
          description: "Sử dụng RAM đã đạt {{ humanize $value }}% (Trống dưới 15%)."

      # DISK SPACE CRITICAL: Phân vùng dung lượng trống dưới 5%
      - alert: HostDiskSpaceCritical
        expr: (node_filesystem_size_bytes{fstype=~"ext[2-4]|xfs|btrfs"} - node_filesystem_free_bytes{fstype=~"ext[2-4]|xfs|btrfs"}) / node_filesystem_size_bytes{fstype=~"ext[2-4]|xfs|btrfs"} * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Ổ cứng sắp đầy nghiêm trọng (Host: {{ $labels.instance }}, Mount: {{ $labels.mountpoint }})"
          description: "Phân vùng {{ $labels.mountpoint }} đã sử dụng {{ humanize $value }}% dung lượng (Trống dưới 5%). Hệ thống có thể bị khóa ghi đĩa."

      # DISK SPACE WARNING: Phân vùng dung lượng trống dưới 15%
      - alert: HostDiskSpaceWarning
        expr: (node_filesystem_size_bytes{fstype=~"ext[2-4]|xfs|btrfs"} - node_filesystem_free_bytes{fstype=~"ext[2-4]|xfs|btrfs"}) / node_filesystem_size_bytes{fstype=~"ext[2-4]|xfs|btrfs"} * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Ổ cứng sắp đầy (Host: {{ $labels.instance }}, Mount: {{ $labels.mountpoint }})"
          description: "Phân vùng {{ $labels.mountpoint }} đã sử dụng {{ humanize $value }}% dung lượng (Trống dưới 15%)."

      # DISK PREDICTIVE WARNING: Dự báo phân vùng sẽ đầy trong vòng 24 giờ tới dựa trên tốc độ ghi hiện tại
      - alert: HostDiskFillingUpIn24Hours
        expr: predict_linear(node_filesystem_free_bytes{fstype=~"ext[2-4]|xfs|btrfs"}[1h], 86400) < 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Cảnh báo sớm: Phân vùng sẽ đầy trong 24h (Host: {{ $labels.instance }}, Mount: {{ $labels.mountpoint }})"
          description: "Dựa trên xu hướng ghi đĩa trong 1 giờ qua, phân vùng {{ $labels.mountpoint }} sẽ hết dung lượng trống trong vòng 24 giờ tới."

      # NETWORK WARNING: Có lỗi xảy ra trên luồng nhận hoặc gửi gói tin mạng
      - alert: HostNetworkErrors
        expr: rate(node_network_receive_errs_total[2m]) > 5 or rate(node_network_transmit_errs_total[2m]) > 5
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Phát hiện lỗi truyền tải mạng (Host: {{ $labels.instance }})"
          description: "Thiết bị mạng đang gặp lỗi nhận hoặc gửi gói tin (> 5 lỗi/giây)."

  # ============================================================================
  # GROUP 3: DOCKER CONTAINER MONITORING (GIÁM SÁT CONTAINER DOCKER)
  # ============================================================================
  - name: docker_containers
    rules:
      # CONTAINER CRITICAL: Cảnh báo khi container mong muốn (ví dụ: fake-logs) không còn chạy (Đã tắt / Comment)
      # - alert: SpecificContainerDown
      #   expr: absent(container_memory_usage_bytes{name="fake-logs"})
      #   for: 30s
      #   labels:
      #     severity: critical
      #   annotations:
      #     summary: "Container fake-logs bị sập"
      #     description: "Không tìm thấy dữ liệu bộ nhớ của container 'fake-logs' trong hơn 30 giây."

      # CONTAINER WARNING: Phát hiện vòng lặp restart (Restart Loop / CrashLoopBackOff)
      - alert: ContainerRestartLoop
        expr: changes(container_start_time_seconds{name!=""}[15m]) > 2
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "Container liên tục khởi động lại (Container: {{ $labels.name }})"
          description: "Container '{{ $labels.name }}' trên node '{{ $labels.instance }}' đã khởi động lại hơn 2 lần trong vòng 15 phút qua."

      # CONTAINER WARNING: Container sử dụng RAM vượt quá 85% giới hạn cấu hình (Limit)
      - alert: ContainerMemoryUsageWarning
        expr: (container_memory_working_set_bytes{name!=""} / container_spec_memory_limit_bytes{name!=""}) * 100 > 85
        for: 3m
        labels:
          severity: warning
        annotations:
          summary: "Container sử dụng RAM cao (Container: {{ $labels.name }})"
          description: "Container '{{ $labels.name }}' đã dùng {{ humanize $value }}% lượng RAM được giới hạn (Vượt ngưỡng 85%)."

      # CONTAINER CRITICAL: Container sử dụng RAM vượt quá 95% giới hạn (Nguy cơ OOMKilled)
      - alert: ContainerMemoryUsageCritical
        expr: (container_memory_working_set_bytes{name!=""} / container_spec_memory_limit_bytes{name!=""}) * 100 > 95
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Nguy cơ OOM: Container cạn kiệt RAM (Container: {{ $labels.name }})"
          description: "Container '{{ $labels.name }}' đã dùng {{ humanize $value }}% lượng RAM tối đa. Nguy cơ cao bị hệ điều hành tắt do hết bộ nhớ (OOM Killed)."

      # CONTAINER INFO: Phát hiện Container CPU cao
      - alert: ContainerCpuUsageHigh
        expr: sum by(instance, name, host_ip) (rate(container_cpu_usage_seconds_total{name!=""}[2m])) * 100 > 80
        for: 5m
        labels:
          severity: info
        annotations:
          summary: "Container CPU tăng cao (Container: {{ $labels.name }})"
          description: "Container '{{ $labels.name }}' đang tiêu hao {{ humanize $value }}% CPU core liên tục trong 5 phút."
